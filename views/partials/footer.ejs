    </main>
  </div>
<script>
  function addItemRow() {
    const wrap = document.getElementById('items-wrap');
    if (!wrap) return;
    const row = document.createElement('div');
    row.className = 'item-row';
    row.innerHTML = `
      <input name="itemName" placeholder="Prodotto" />
      <input name="itemQty" type="number" min="0" step="0.01" placeholder="Q.tà" />
      <input name="itemUnit" placeholder="Unità" value="kg" />
      <input name="itemPrice" type="number" min="0" step="0.01" placeholder="Prezzo" />
    `;
    wrap.appendChild(row);
  }
</script>
</body>
</html>
